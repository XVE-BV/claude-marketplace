# Copy values to ~/.zshrc exports or a sourced .env — never commit actual values

# ── Identity ─────────────────────────────────────────────────────
XVE_EMAIL=your@email.com

# ── Claude session config ─────────────────────────────────────────
# Advisor: set to 1 to disable Opus advisor (faster/cheaper, less strategic oversight)
# DISABLE_ADVISOR=1

# Kimai/ClockIt: set to 1 to enable time tracking agent + /k /ks /ke commands
# ENABLE_KIMAI=1

# ActivityWatch: set to 1 to enable AW agent + /aw /aw-week /aw-setup commands
# ENABLE_ACTIVITYWATCH=1

# ── Kimai / ClockIt ──────────────────────────────────────────────
CLOCKIT_TOKEN=your_bearer_token_here
CLOCKIT_BASE=https://your-kimai-instance.example/api

# ── Customer mappings ────────────────────────────────────────────
# Format per entry: "path_hint|kimai_project_id|display_label|aw_pattern"
# path_hint   = substring matched against CWD (grep -iE)
# aw_pattern  = regex matched against window titles / URLs / file paths
# Order matters: more specific entries must come before broader ones
#
# XVE_CUSTOMER_1="dwb|7|DWB|(?i)dwb"
# XVE_CUSTOMER_2="nassautechnics|5|Nassau Technics|(?i)nassau\.tech|nassautechnics"
# XVE_CUSTOMER_3="nassau|12|Nassau|(?i)nassau"
# XVE_CUSTOMER_4="btb|8|BTB|(?i)btb"
# XVE_CUSTOMER_5="peppol|153|Peppol|(?i)peppol"

XVE_CUSTOMER_1=""
XVE_CUSTOMER_2=""
XVE_CUSTOMER_3=""
XVE_CUSTOMER_4=""
XVE_CUSTOMER_5=""

# ── ActivityWatch exclusions ─────────────────────────────────────
# Regex — titles/URLs matching this are never counted or billed
# AW_EXCLUDE="(?i)your-internal-tool|your-other-tool"
AW_EXCLUDE=""

# ── Internal Kimai project (fallback for non-client work) ────────
# KIMAI_INTERNAL_ID=141
KIMAI_INTERNAL_ID=""
