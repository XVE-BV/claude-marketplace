{
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "BASH_DEFAULT_TIMEOUT_MS": "120000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "40000",
    "DISABLE_COST_WARNINGS": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_ADAPTIVE_THINKING": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(ssh *)",
      "Bash(ssh-keygen *)",
      "Bash(ssh-add *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(php *)",
      "Bash(composer *)",
      "Bash(vendor/bin/*)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(env)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(* --version)",
      "Bash(* --help)",
      "Bash(* --help *)",
      "Bash(jq *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(tar *)",
      "Bash(unzip *)",
      "Bash(zip *)",
      "Bash(ps *)",
      "Bash(kill *)",
      "Bash(lsof *)",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "Task"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push * --force)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(git clean -fd *)",
      "Bash(git branch -D *)",
      "Bash(rm -rf *)",
      "Bash(rm -r /*)",
      "Bash(sudo rm *)",
      "Bash(chmod -R 777 *)",
      "Bash(dd if=* of=*)",
      "Bash(mkfs *)",
      "Bash(fdisk *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "sonnet",
  "effortLevel": "xhigh",
  "advisorModel": "opus",
  "autoMemoryDirectory": "~/.claude/memory/",
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/session-start.sh",
            "statusMessage": "Loading session config..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/xve/.claude/clockit-stop.sh",
            "asyncRewake": true,
            "statusMessage": "ClockIt check..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"If the user stated a factual claim or assertion, verify it and explicitly confirm or correct it before responding.\"}}'",
            "statusMessage": "Checking assertions..."
          }
        ]
      }
    ]
  }
}
